            <section class="ds-gm-command-grid">
              <form class="ds-panel" data-action-form="updatePermissions"><input type="hidden" name="settlementId" value="{{selected.id}}"><div class="ds-panel-heading"><h2>Player Permissions</h2><button type="submit"><i class="fa-solid fa-floppy-disk"></i></button></div><label><input type="checkbox" name="playersCanEditBasics" data-bool {{#if selected.permissions.playersCanEditBasics}}checked{{/if}}> Edit settlement profile</label><label><input type="checkbox" name="playersCanEditAssignments" data-bool {{#if selected.permissions.playersCanEditAssignments}}checked{{/if}}> Edit POP, regiment names and images</label><label><input type="checkbox" name="playersCanManageConstruction" data-bool {{#if selected.permissions.playersCanManageConstruction}}checked{{/if}}> Manage construction</label><label><input type="checkbox" name="playersCanManageRecruitment" data-bool {{#if selected.permissions.playersCanManageRecruitment}}checked{{/if}}> Recruit units</label><label><input type="checkbox" name="playersCanWriteTurnNotes" data-bool {{#if selected.permissions.playersCanWriteTurnNotes}}checked{{/if}}> Write turn notes</label></form>
              <form class="ds-panel" data-action-form="updateOverrides"><input type="hidden" name="settlementId" value="{{selected.id}}"><div class="ds-panel-heading"><h2>Rule Overrides</h2><button type="submit"><i class="fa-solid fa-floppy-disk"></i></button></div><label><input type="checkbox" name="ignorePopulationLimits" data-bool {{#if selected.overrides.ignorePopulationLimits}}checked{{/if}}> Ignore population progression limits</label><label><input type="checkbox" name="ignoreManpowerLimits" data-bool {{#if selected.overrides.ignoreManpowerLimits}}checked{{/if}}> Ignore manpower limits</label><label><input type="checkbox" name="ignoreMilitaryCapacity" data-bool {{#if selected.overrides.ignoreMilitaryCapacity}}checked{{/if}}> Ignore military capacity</label><label><input type="checkbox" name="ignoreBuildingRequirements" data-bool {{#if selected.overrides.ignoreBuildingRequirements}}checked{{/if}}> Ignore building and terrain requirements</label><label><input type="checkbox" name="ignoreSlotLimits" data-bool {{#if selected.overrides.ignoreSlotLimits}}checked{{/if}}> Ignore slot limits</label><label><input type="checkbox" name="ignoreGrowthLimits" data-bool {{#if selected.overrides.ignoreGrowthLimits}}checked{{/if}}> Ignore growth clamp</label></form>
            </section>

            <section class="ds-danger-zone"><div><h2>Settlement Record</h2><p>De Laurent is never overwritten by settlement templates.</p></div><button type="button" class="ds-danger" data-click-action="deleteSettlement" data-settlement-id="{{selected.id}}" data-confirm="Delete this settlement?"><i class="fa-solid fa-trash"></i><span>Delete Settlement</span></button></section>
          </section>
        {{/if}}
      {{/if}}
    </main>
  </div>
</div>
