                <label><span>Building or Landmark</span><select name="catalogId">{{#each gmBuildingOptions}}<option value="{{id}}">{{label}}</option>{{/each}}</select></label>
                <label><span>District for Normal Building</span><select name="slotId"><option value="">First compatible empty district / none for landmark</option>{{#each selected.slots}}{{#if availableForDirectAdd}}<option value="{{id}}">{{label}} / {{allowedCategory}}</option>{{/if}}{{/each}}</select></label>
                <label class="ds-toggle"><input type="checkbox" name="chargeResources" data-bool checked><span>Charge normal Crown and Materials</span></label>
              </form>
              <section class="ds-panel">
                <div class="ds-panel-heading"><div><h2>Direct Military Tools</h2><p>GM bypasses recruitment-building requirements</p></div></div>
