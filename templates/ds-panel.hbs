              <form class="ds-panel" data-action-form="processSettlement"><input type="hidden" name="settlementId" value="{{selected.id}}"><div class="ds-panel-heading"><div><h2>Selected Settlement</h2><p>{{selected.processStatusLabel}}{{#if selected.hasPendingEvents}} / Resolve pending event first{{/if}}</p></div></div><label><span>GM Turn Note</span><textarea name="gmTurnNote" rows="2"></textarea></label><div class="ds-record-actions"><button type="submit" class="ds-primary" {{#unless selected.canProcessThisMonth}}disabled{{/unless}}><i class="fa-solid fa-forward-step"></i><span>Process {{selected.name}}</span></button><button type="button" class="ds-danger" data-click-action="processSettlement" data-settlement-id="{{selected.id}}" data-force="true" data-confirm="Process this settlement again for the same month?" {{#if selected.hasPendingEvents}}disabled{{/if}}><i class="fa-solid fa-rotate"></i><span>Force</span></button></div></form>
              <form class="ds-panel" data-action-form="processTurn" data-confirm="Process every pending settlement and close this month?"><div class="ds-panel-heading"><div><h2>Close Global Month</h2><p>{{#if hasWorldPendingEvents}}Resolve {{pendingWorldEventCount}} pending event(s) first{{else}}Only pending settlements are processed{{/if}}</p></div></div><label><span>GM Turn Note</span><textarea name="gmTurnNote" rows="2"></textarea></label><button type="submit" class="ds-danger" {{#if hasWorldPendingEvents}}disabled{{/if}}><i class="fa-solid fa-forward-fast"></i><span>Close Month {{month}}</span></button></form>
              <form class="ds-panel" data-action-form="addSettlement"><div class="ds-panel-heading"><h2>Create Settlement</h2><button type="submit"><i class="fa-solid fa-plus"></i></button></div><label><span>Name</span><input name="name" value="New Settlement"></label><label><span>Template</span><select name="templateId">{{#each settlementTemplates}}<option value="{{id}}">{{name}}</option>{{/each}}</select></label></form>
            </section>

            <section class="ds-gm-command-grid">
              <form class="ds-panel" data-action-form="updatePopulation">
                <input type="hidden" name="settlementId" value="{{selected.id}}">
                <div class="ds-panel-heading"><div><h2>Settlement Ledger</h2><p>GM corrections apply immediately</p></div><button type="submit"><i class="fa-solid fa-floppy-disk"></i></button></div>
                <div class="ds-form-grid">
                  <label><span>Population</span><input type="number" name="population" value="{{selected.population}}" min="0"></label>
                  <label><span>Treasure</span><input type="number" name="treasure" value="{{selected.treasureValue}}"></label>
                  <label><span>Materials</span><input type="number" name="materials" value="{{selected.materialsValue}}" min="0"></label>
                  <label><span>Public Order</span><input type="number" name="publicOrder" value="{{selected.publicOrderValue}}" min="0" max="100"></label>
                  <label><span>Manpower Bonus</span><input type="number" name="manpowerBonus" value="{{selected.manpowerBonus}}"></label>
                  <label><span>Manpower Override</span><input type="number" name="manpowerOverride" value="{{selected.manpowerOverride}}" placeholder="Automatic"></label>
                  <label><span>Manpower Reserve</span><input type="number" name="manpowerReserve" value="{{selected.manpowerReserveValue}}" min="0"></label>
                  <label><span>Bonus Slots</span><input type="number" name="slotBonus" value="{{selected.slotBonus}}" min="0"></label>
                </div>
              </form>
              <form class="ds-panel" data-action-form="setSettlementTier">
                <input type="hidden" name="settlementId" value="{{selected.id}}">
                <div class="ds-panel-heading"><div><h2>Settlement Rank</h2><p>Current: {{selected.tierLabel}}</p></div><button type="submit"><i class="fa-solid fa-arrow-up-right-dots"></i></button></div>
                <label><span>Set Rank Directly</span><select name="tier">{{#each selected.tierOptions}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>{{/each}}</select></label>
                <label><span>GM Note</span><textarea name="note" rows="3" placeholder="Reason for manual change"></textarea></label>
                <p class="ds-callout">This bypasses progression costs and population requirements, then recalculates district slots.</p>
              </form>
            </section>

            <form class="ds-panel" data-action-form="updateVisuals">
