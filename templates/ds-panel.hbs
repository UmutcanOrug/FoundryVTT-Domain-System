<div class="ds-root {{#unless isGM}}ds-player{{/unless}}">
  <header class="ds-header">
    <div class="ds-title">
      <span class="ds-title-mark"><i class="fa-solid fa-building-columns"></i></span>
      <div>
        <h1>DS: Domain System</h1>
        <p>Month {{month}}{{#if selected}} / {{selected.name}} / {{selected.tierLabel}}{{/if}}</p>
      </div>
    </div>

    {{#if selected}}
      <div class="ds-resource-strip">
        <div class="ds-resource"><i class="fa-solid fa-users"></i><span>Total POP</span><strong>{{selected.summary.totalPop}}</strong></div>
        <div class="ds-resource"><i class="fa-solid fa-person-digging"></i><span>Free POP</span><strong>{{selected.summary.freePop}}</strong></div>
        <div class="ds-resource" title="Recovers {{selected.summary.manpowerRecovery}} per processed month; force capacity remaining {{selected.summary.forceCapacityAvailable}}"><i class="fa-solid fa-khanda"></i><span>Manpower Reserve</span><strong>{{selected.summary.manpowerReserve}} / {{selected.summary.manpowerCap}}</strong></div>
        <div class="ds-resource"><i class="fa-solid fa-vault"></i><span>Treasure</span><strong>{{selected.treasure}}</strong></div>
        <div class="ds-resource" title="Monthly production / consumption"><i class="fa-solid fa-wheat-awn"></i><span>Food Flow</span><strong>{{selected.summary.foodProduction}} / {{selected.summary.foodConsumption}}</strong></div>
        <div class="ds-resource"><i class="fa-solid fa-cubes-stacked"></i><span>Materials</span><strong>{{selected.materials}}</strong></div>
        <div class="ds-resource" title="Raised army plus free settlement garrison"><i class="fa-solid fa-shield-halved"></i><span>Defense Power</span><strong>{{selected.summary.defendingPower}}</strong></div>
        <div class="ds-resource"><i class="fa-solid fa-scale-balanced"></i><span>Net</span><strong>{{selected.summary.netIncome}}</strong></div>
      </div>
    {{/if}}
  </header>

  <div class="ds-shell">
    <aside class="ds-sidebar">
      <div class="ds-search-row">
        <input type="search" data-search-settlements value="{{search}}" placeholder="Search settlements">
        {{#if isGM}}<button type="button" data-click-action="addSettlement" title="Create Starter Village"><i class="fa-solid fa-plus"></i></button>{{/if}}
      </div>
      <div class="ds-settlement-list">
        {{#each settlements}}
          <button type="button" class="ds-settlement-button {{#if active}}active{{/if}}" data-select-settlement="{{id}}">
            <strong>{{name}}</strong>
            <span>{{type}} / {{region}}</span>
            <small>POP {{pop}} / Net {{net}}{{#if processedThisMonth}} / Processed{{else}} / Pending{{/if}}{{#if warnings}} / {{warnings}} warnings{{/if}}</small>
          </button>
        {{/each}}
      </div>
    </aside>

    <main class="ds-main">
      {{#unless hasVisibleSettlements}}<section class="ds-empty"><h2>No Settlement Assigned</h2></section>{{/unless}}

      {{#if selected}}
        {{#if selected.hasWarnings}}
          <section class="ds-warning-band">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div>{{#each selected.warnings}}<p>{{this}}</p>{{/each}}</div>
          </section>
        {{/if}}

        <nav class="ds-nav" aria-label="Domain System sections">
          {{#each tabs}}
            <button type="button" class="ds-nav-item {{#if active}}active{{/if}}" data-tab="{{id}}" title="{{label}}">
              <i class="fa-solid {{icon}}"></i><span>{{label}}</span>
            </button>
          {{/each}}
        </nav>

        {{#if (eq activeTab "overview")}}
          <section class="ds-pane">
            <section class="ds-planet-hero" style="{{selected.heroStyle}}">
              <div class="ds-hero-copy">
                <span class="ds-kicker">{{selected.tierLabel}} / {{selected.region}}</span>
                <h2>{{selected.name}}</h2>
                <p>{{selected.systemNotes}}</p>
                <div class="ds-chip-row">
                  <span><i class="fa-solid fa-landmark"></i> {{selected.coreName}}</span>
                  <span><i class="fa-solid fa-layer-group"></i> {{selected.summary.slotUsage}} slots</span>
                  <span class="{{#if selected.processedThisMonth}}ds-good{{else}}ds-warn{{/if}}"><i class="fa-solid fa-calendar-check"></i> {{selected.processStatusLabel}}</span>
                </div>
              </div>
              <div class="ds-advisor-block">
                <div class="ds-advisor-portrait">{{#if selected.portraitUrl}}<img src="{{selected.portraitUrl}}" alt="Advisor">{{else}}<i class="fa-solid fa-user-tie"></i>{{/if}}</div>
                <div><span>Governor</span><strong>{{selected.governorName}}</strong><small>{{selected.ownerNames}}</small></div>
              </div>
            </section>

            <section class="ds-metrics-grid ds-overview-metrics">
              <div><span>Gross Income</span><strong>{{selected.summary.grossIncome}}</strong></div>
              <div><span>Food / Month</span><strong>{{selected.summary.foodBalance}}</strong></div>
              <div><span>Food Security</span><strong class="{{selected.summary.foodSecurityClass}}">{{selected.summary.foodSecurity}} / {{selected.summary.foodCoverage}}</strong><small>{{selected.summary.foodSecurityGrowth}}</small></div>
              <div><span>Materials / Month</span><strong>{{selected.summary.materialsBalance}}</strong></div>
              <div><span>Public Order</span><strong class="{{selected.summary.publicOrderBandClass}}">{{selected.summary.publicOrder}} / {{selected.summary.publicOrderBand}}</strong><small>{{selected.summary.publicOrderGrowth}} / {{selected.summary.publicOrderIncome}}</small></div>
              <div><span>Construction CP</span><strong>{{selected.summary.cpThisMonth}}</strong></div>
              <div><span>Auto Garrison</span><strong>{{selected.summary.autoGarrisonPower}} Power</strong><small>{{selected.summary.siegeDefense}} siege defense / {{selected.summary.autoGarrisonSummary}}</small></div>
            </section>

            {{#if selected.hasActiveEffects}}
              <section class="ds-active-effects-band">
                <div class="ds-section-heading"><h2><i class="fa-solid fa-bolt"></i> Active Modifiers</h2></div>
                <div class="ds-active-effect-strip">{{#each selected.activeEffects}}<article><strong>{{name}}</strong><span>{{effectsText}}</span><small>{{remainingLabel}}</small></article>{{/each}}</div>
              </section>
            {{/if}}

            <section class="ds-command-grid ds-overview-command-grid">
              <div class="ds-section">
                <div class="ds-section-heading"><h2><i class="fa-solid fa-hammer"></i> Construction Queue</h2><span>{{selected.summary.cpThisMonth}} base CP</span></div>
                {{#each selected.activeProjects}}
                  <article class="ds-compact-row"><span class="ds-row-icon"><i class="fa-solid {{categoryIcon}}"></i></span><div><strong>#{{queueNumber}} {{name}}</strong><small>{{cpPaidDisplay}} / {{requiredCpDisplay}} CP / ETA {{months}} month(s)</small></div><span>{{statusLabel}}</span></article>
                {{else}}<div class="ds-inline-empty">No active construction.</div>{{/each}}
              </div>
              <div class="ds-section">
                <div class="ds-section-heading"><h2><i class="fa-solid fa-user-plus"></i> Recruitment Queue</h2><span>{{selected.summary.recruitmentCapacity}} capacity</span></div>
                {{#each selected.activeRecruitment}}
                  <article class="ds-compact-row"><span class="ds-row-icon"><i class="fa-solid fa-user-shield"></i></span><div><strong>{{regimentName}}</strong><small>{{troopTypeName}} / {{progress}} / {{sourceName}}</small></div><span>{{statusLabel}}</span></article>
                {{else}}<div class="ds-inline-empty">No active recruitment.</div>{{/each}}
                {{#if selected.activeReplenishment}}<div class="ds-mini-queue-label"><i class="fa-solid fa-kit-medical"></i><strong>Month-End Replenishment</strong><span>No recruitment capacity cost</span></div>{{/if}}
                {{#each selected.activeReplenishment}}<article class="ds-compact-row"><span class="ds-row-icon"><i class="fa-solid fa-kit-medical"></i></span><div><strong>{{regimentName}}</strong><small>{{progress}} / {{sourceName}}</small></div><span>Month End</span></article>{{/each}}
              </div>
            </section>

            {{#if selected.hasLandmarks}}
              <section class="ds-landmark-band">
                <div class="ds-section-heading"><h2><i class="fa-solid fa-crown"></i> Landmark</h2><span>Unique settlement feature</span></div>
                <div class="ds-landmark-strip">
                  {{#each selected.landmarks}}
                    <article class="ds-landmark-card {{branchClass}}">
                      {{#if hasImage}}<img src="{{imageUrl}}" alt="{{name}}">{{else}}<i class="fa-solid fa-crown"></i>{{/if}}
                      <div><strong>{{name}}</strong><p>{{description}}</p><small>{{operationLabel}} / requires {{requiredWorkersDisplay}} POP</small><span class="ds-effect-badges">{{#each effectBadges}}<em class="{{kind}}"><i class="fa-solid {{icon}}"></i>{{label}}</em>{{/each}}</span></div>
                      {{#if canEditAssignments}}<button type="button" data-click-action="toggleBuildingOperation" data-settlement-id="{{@root.selected.id}}" data-building-id="{{id}}" data-operation="{{operationAction}}" title="{{operationButtonLabel}}"><i class="fa-solid {{#if active}}fa-pause{{else}}fa-play{{/if}}"></i></button>{{/if}}
                    </article>
                  {{/each}}
                </div>
              </section>
            {{/if}}

            <section class="ds-section ds-overview-districts" style="{{selected.districtStyle}}">
              <div class="ds-section-heading ds-district-heading">
                <div><h2>Settlement Districts</h2><span>{{selected.summary.usedSlots}} used / {{selected.summary.unlockedSlots}} unlocked</span></div>
                <div class="ds-district-pagination">
                  <button type="button" data-district-page-delta="-1" title="Previous districts" {{#unless selected.districtBoard.hasPrevious}}disabled{{/unless}}><i class="fa-solid fa-chevron-left"></i></button>
                  <span>{{selected.districtBoard.pageStart}}-{{selected.districtBoard.pageEnd}} / {{selected.districtBoard.total}}</span>
                  <button type="button" data-district-page-delta="1" title="Next districts" {{#unless selected.districtBoard.hasNext}}disabled{{/unless}}><i class="fa-solid fa-chevron-right"></i></button>
                </div>
              </div>

              <div class="ds-overview-slot-grid">
                {{#each selected.districtBoard.slots}}
                  <button type="button" data-overview-slot-id="{{id}}" class="ds-overview-slot {{#if selected}}selected{{/if}} {{#if locked}}locked{{/if}} {{#if occupied}}{{building.branchClass}}{{/if}}">
                    {{#if locked}}
                      <i class="fa-solid fa-lock"></i><strong>{{label}}</strong><small>{{unlockCostDisplay}} Crown</small>
                    {{else if supportSlot}}
                      <i class="fa-solid fa-link"></i><strong>{{label}}</strong><small>{{supportLabel}}</small>
                    {{else if hasProject}}
                      {{#if project.hasImage}}<img src="{{project.imageUrl}}" alt="{{project.name}}">{{else}}<i class="fa-solid fa-hammer"></i>{{/if}}<strong>{{project.name}}</strong><small>{{project.progressPercent}}% / {{project.statusLabel}}</small><span class="ds-slot-status"><i class="fa-solid fa-hammer"></i></span>
                    {{else if occupied}}
                      {{#if building.hasImage}}<img src="{{building.imageUrl}}" alt="{{building.name}}">{{else}}<i class="fa-solid {{building.categoryIcon}}"></i>{{/if}}
                      <strong>{{building.name}}</strong><small>{{building.branchLabel}} / {{building.operationLabel}}</small><span class="ds-tier-badge">{{building.tierRoman}}</span>
                    {{else}}
                      <i class="fa-solid fa-plus"></i><strong>{{label}}</strong><small>Choose district</small>
                    {{/if}}
                  </button>
                {{/each}}
              </div>

              {{#if selected.districtBoard.picker}}
                <aside class="ds-district-branch-overlay">
                  <header><div><span>{{selected.districtBoard.picker.label}}</span><h3>{{#if selected.districtBoard.picker.occupied}}{{selected.districtBoard.picker.current.name}}{{else}}Choose a Building Branch{{/if}}</h3></div><button type="button" data-close-district-picker title="Close branch selector"><i class="fa-solid fa-xmark"></i></button></header>

                  {{#if selected.districtBoard.picker.locked}}
                    <div class="ds-picker-message"><i class="fa-solid fa-lock"></i><p>This district costs {{selected.districtBoard.picker.unlockCostDisplay}} Crown to unlock.</p><button type="button" data-click-action="unlockSlot" data-settlement-id="{{selected.id}}" data-slot-id="{{selected.districtBoard.picker.slotId}}" {{#unless selected.districtBoard.picker.canUnlock}}disabled{{/unless}}><i class="fa-solid fa-unlock"></i><span>Unlock District</span></button></div>
                  {{else if selected.districtBoard.picker.supportSlot}}
                    <div class="ds-picker-message"><i class="fa-solid fa-link"></i><p>{{selected.districtBoard.picker.supportLabel}}</p></div>
                  {{else if selected.districtBoard.picker.hasProject}}
                    <div class="ds-picker-message"><i class="fa-solid fa-hammer"></i><p>{{selected.districtBoard.picker.project.name}}: {{selected.districtBoard.picker.project.cpPaidDisplay}} / {{selected.districtBoard.picker.project.requiredCpDisplay}} CP</p></div>
                  {{else if selected.districtBoard.picker.isRootPicker}}
                    <div class="ds-branch-workspace">
                      <div class="ds-root-branch-groups">
                        {{#each selected.districtBoard.picker.rootGroups}}
                          <section class="ds-root-branch-group {{className}}"><h4><i class="fa-solid {{icon}}"></i>{{label}}</h4><div>
                            {{#each nodes}}
                              <form data-action-form="queueConstruction" data-branch-detail>
                                <input type="hidden" name="settlementId" value="{{@root.selected.id}}"><input type="hidden" name="slotId" value="{{slotId}}"><input type="hidden" name="catalogId" value="{{id}}">
                                <button type="submit" class="ds-branch-node {{branchClass}}" {{#unless canQueue}}disabled{{/unless}}>
                                  {{#if hasImage}}<img src="{{imageUrl}}" alt="{{name}}">{{else}}<i class="fa-solid {{categoryIcon}}"></i>{{/if}}<strong>{{name}}</strong><span class="ds-tier-badge">{{tierRoman}}</span>
                                  <span class="ds-node-tooltip"><b>{{name}}</b><small>{{description}}</small><span class="ds-effect-badges">{{#each effectBadges}}<em class="{{kind}}"><i class="fa-solid {{icon}}"></i>{{label}}</em>{{/each}}</span><small>{{crownCostDisplay}} Crown / {{materialCostDisplay}} Materials / {{cpCostDisplay}} CP</small><small>{{#if blocked}}{{blockReason}}{{else}}{{requirementDisplay}}{{/if}}</small></span>
                                </button>
                              </form>
                            {{/each}}
                          </div></section>
                        {{/each}}
                      </div>
                      <aside class="ds-branch-detail-panel"><span>Building Details</span><div data-branch-detail-content>{{#with selected.districtBoard.picker.detail}}<b>{{name}}</b><small>{{nodeTierLabel}} / {{branchLabel}}</small><p>{{description}}</p><span class="ds-effect-badges">{{#each effectBadges}}<em class="{{kind}}"><i class="fa-solid {{icon}}"></i>{{label}}</em>{{/each}}</span><small>{{crownCostDisplay}} Crown / {{materialCostDisplay}} Materials / {{cpCostDisplay}} CP</small><small>{{#if blocked}}{{blockReason}}{{else}}{{requirementDisplay}}{{/if}}</small>{{/with}}</div></aside>
                    </div>
                  {{else}}
                    <div class="ds-branch-workspace">
                      <div class="ds-slot-branch-tree {{selected.districtBoard.picker.branchClass}}">
                        {{#each selected.districtBoard.picker.levels}}
                          <div class="ds-slot-tree-tier"><span class="ds-tree-tier-label">Tier {{tierRoman}}</span><div class="ds-slot-tree-nodes" style="--tree-columns: {{columnCount}};">
                            {{#each nodes}}
                              {{#if directChoice}}
                                <form data-action-form="queueConstruction" data-branch-detail style="{{treeStyle}}">
                                  <input type="hidden" name="settlementId" value="{{@root.selected.id}}"><input type="hidden" name="slotId" value="{{slotId}}"><input type="hidden" name="catalogId" value="{{id}}">
                                  <button type="submit" class="ds-branch-node {{branchClass}} available {{#if blocked}}blocked{{/if}}" {{#unless canQueue}}disabled{{/unless}}>
                                    {{#if hasImage}}<img src="{{imageUrl}}" alt="{{name}}">{{else}}<i class="fa-solid {{categoryIcon}}"></i>{{/if}}<strong>{{name}}</strong><small>{{stateLabel}}</small><span class="ds-tier-badge">{{tierRoman}}</span>
                                    <span class="ds-node-tooltip"><b>{{name}}</b><small>{{description}}</small><span class="ds-effect-badges">{{#each effectBadges}}<em class="{{kind}}"><i class="fa-solid {{icon}}"></i>{{label}}</em>{{/each}}</span>{{#if comparisonBadges.length}}<b>Compared with current</b><span class="ds-effect-badges">{{#each comparisonBadges}}<em class="{{kind}}"><i class="fa-solid {{icon}}"></i>{{label}}</em>{{/each}}</span>{{/if}}<small>{{crownCostDisplay}} Crown / {{materialCostDisplay}} Materials / {{cpCostDisplay}} CP</small><small>{{#if blocked}}{{blockReason}}{{else}}{{requirementDisplay}}{{/if}}</small></span>
                                  </button>
                                </form>
                              {{else}}
                                <article class="ds-branch-node {{branchClass}} {{#if isCurrent}}current{{else if completed}}completed{{else}}future{{/if}}" data-branch-detail tabindex="0" style="{{treeStyle}}">
                                  {{#if hasImage}}<img src="{{imageUrl}}" alt="{{name}}">{{else}}<i class="fa-solid {{categoryIcon}}"></i>{{/if}}<strong>{{name}}</strong><small>{{stateLabel}}</small><span class="ds-tier-badge">{{tierRoman}}</span>
                                  <span class="ds-node-tooltip"><b>{{name}}</b><small>{{description}}</small><span class="ds-effect-badges">{{#each effectBadges}}<em class="{{kind}}"><i class="fa-solid {{icon}}"></i>{{label}}</em>{{/each}}</span></span>
                                </article>
                              {{/if}}
                            {{/each}}
                          </div></div>
                        {{/each}}
                      </div>
                      <aside class="ds-branch-detail-panel"><span>Building Details</span><div data-branch-detail-content>{{#with selected.districtBoard.picker.detail}}<b>{{name}}</b><small>{{nodeTierLabel}} / {{branchLabel}}</small><p>{{description}}</p><span class="ds-effect-badges">{{#each effectBadges}}<em class="{{kind}}"><i class="fa-solid {{icon}}"></i>{{label}}</em>{{/each}}</span><small>{{crownCostDisplay}} Crown / {{materialCostDisplay}} Materials / {{cpCostDisplay}} CP</small><small>{{requirementDisplay}}</small>{{/with}}</div></aside>
                    </div>
                  {{/if}}
                </aside>
              {{/if}}
            </section>

            <section class="ds-section ds-overview-forces">
              <div class="ds-section-heading"><h2>Raised Forces</h2><span>{{selected.summary.armyPower}} Power / {{selected.summary.troopManpowerUsed}} of {{selected.summary.manpowerCap}} manpower</span></div>
              <div class="ds-regiment-strip">
                {{#each selected.troops}}
                  <article class="ds-regiment-chip">{{#if hasImage}}<img src="{{imageUrl}}" alt="{{displayName}}">{{else}}<i class="fa-solid fa-shield-halved"></i>{{/if}}<div><strong>{{displayName}}</strong><small>{{strengthLabel}} strength / Power {{power}} / {{cost}} upkeep</small></div></article>
                {{else}}<div class="ds-inline-empty">No raised forces.</div>{{/each}}
              </div>
            </section>
          </section>
        {{/if}}

        {{#if (eq activeTab "town")}}
          <section class="ds-pane">
            <section class="ds-progression-band">
              <div class="ds-tier-current"><span>Current Settlement</span><strong>{{selected.progression.current.name}}</strong><small>{{selected.progression.current.coreName}} / {{selected.progression.current.openSlots}} open slots</small></div>
              <div class="ds-tier-track"><div style="width: {{selected.progression.populationProgress}}%"></div></div>
              {{#if selected.progression.hasNext}}
                <div class="ds-tier-next"><span>Next Settlement</span><strong>{{selected.progression.next.name}}</strong><small>{{selected.progression.next.minPopulationDisplay}} POP / {{selected.progression.next.promotionCostDisplay}} Crown / {{selected.progression.next.promotionMaterialsDisplay}} Materials / {{selected.progression.next.promotionCpDisplay}} CP</small></div>
                <form data-action-form="queueSettlementUpgrade">
                  <input type="hidden" name="settlementId" value="{{selected.id}}">
                  <button type="submit" class="ds-primary" {{#unless selected.progression.canQueue}}disabled{{/unless}} title="{{selected.progression.blockedReason}}"><i class="fa-solid fa-landmark"></i><span>Develop {{selected.progression.next.coreName}}</span></button>
                </form>
              {{else}}<strong>Maximum settlement tier reached</strong>{{/if}}
            </section>

            <section class="ds-town-grid">
              <form class="ds-panel" data-action-form="updateBasics">
                <input type="hidden" name="settlementId" value="{{selected.id}}">
                <div class="ds-panel-heading"><h2>Settlement Profile</h2><button type="submit" title="Save" {{#unless selected.canEditBasics}}disabled{{/unless}}><i class="fa-solid fa-floppy-disk"></i></button></div>
                <div class="ds-form-grid">
                  <label><span>Name</span><input name="name" value="{{selected.name}}" {{#unless selected.canEditBasics}}disabled{{/unless}}></label>
                  <label><span>Region</span><input name="region" value="{{selected.region}}" {{#unless selected.canEditBasics}}disabled{{/unless}}></label>
                  <fieldset class="ds-full ds-check-grid"><legend>Terrain</legend>{{#each selected.terrainOptions}}<label><input type="checkbox" name="terrainTags" value="{{name}}" {{#if checked}}checked{{/if}} {{#unless @root.selected.canEditBasics}}disabled{{/unless}}><span>{{name}}</span></label>{{/each}}</fieldset>
                  <label class="ds-full"><span>Custom Terrain Tags</span><input name="customTerrainTags" value="{{selected.customTerrainTagsText}}" {{#unless selected.canEditBasics}}disabled{{/unless}}></label>
                  <label class="ds-full"><span>Public Notes</span><textarea name="notes" rows="3" {{#unless selected.canEditBasics}}disabled{{/unless}}>{{selected.notes}}</textarea></label>
                </div>
              </form>

              <form class="ds-panel ds-policy-panel" data-action-form="updatePolicy">
                <input type="hidden" name="settlementId" value="{{selected.id}}">
                <div class="ds-panel-heading"><h2><i class="fa-solid fa-scroll"></i> Settlement Policy</h2><button type="submit" {{#unless selected.access.canEditAssignments}}disabled{{/unless}} title="Apply policy"><i class="fa-solid fa-check"></i></button></div>
                <label><span>Active Policy</span><select name="policyId" {{#unless selected.access.canEditAssignments}}disabled{{/unless}}>{{#each selected.policyOptions}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}} / {{tierLabel}}</option>{{/each}}</select></label>
                <p>{{selected.policy.description}}</p>
              </form>

              <form class="ds-panel ds-treasury-transfer" data-action-form="transferTreasure">
                <input type="hidden" name="settlementId" value="{{selected.id}}">
                <div class="ds-panel-heading"><div><h2><i class="fa-solid fa-vault"></i> Treasury</h2><p>{{selected.treasure}} Crown available</p></div></div>
                <label><span>Transfer Amount</span><input type="number" name="amount" value="1000" min="1" {{#unless selected.access.canTransferTreasure}}disabled{{/unless}}></label>
                <div class="ds-record-actions"><button type="submit" name="direction" value="deposit" {{#unless selected.access.canTransferTreasure}}disabled{{/unless}}><i class="fa-solid fa-arrow-down"></i><span>Deposit</span></button><button type="submit" name="direction" value="withdraw" {{#unless selected.access.canTransferTreasure}}disabled{{/unless}}><i class="fa-solid fa-arrow-up"></i><span>Withdraw</span></button></div>
              </form>

              <section class="ds-panel">
                <div class="ds-panel-heading"><h2>Population and Growth</h2></div>
                <div class="ds-metrics-grid">
                  <div><span>Total POP</span><strong>{{selected.summary.totalPop}}</strong></div>
                  <div><span>Represented People</span><strong>{{selected.summary.representedPeople}}</strong></div>
                  <div><span>Economic Workers</span><strong>{{selected.summary.economicWorkers}}</strong></div>
                  <div><span>Military Staff</span><strong>{{selected.summary.militaryWorkers}}</strong></div>
                  <div><span>Free POP</span><strong>{{selected.summary.freePop}}</strong></div>
                  <div><span>Army Manpower</span><strong>{{selected.summary.troopManpowerUsed}}</strong></div>
                  <div><span>Manpower Cap</span><strong>{{selected.summary.manpowerCap}}</strong></div>
                  <div><span>Available Manpower</span><strong>{{selected.summary.manpowerAvailable}}</strong></div>
                  <div><span>Growth Rate</span><strong>{{selected.summary.growthRate}}</strong></div>
                  <div><span>Building Growth</span><strong>{{selected.summary.buildingGrowth}}</strong></div>
                  <div><span>Population Pressure</span><strong class="ds-warn">{{selected.summary.populationPressure}}</strong></div>
                  <div><span>Food Security</span><strong class="{{selected.summary.foodSecurityClass}}">{{selected.summary.foodSecurity}} / {{selected.summary.foodCoverage}}</strong></div>
                  <div><span>Monthly Change</span><strong>{{selected.summary.popChange}}</strong></div>
                </div>
                {{#if isGM}}
                  <form data-action-form="updateGrowth" class="ds-form-grid ds-top-gap">
                    <input type="hidden" name="settlementId" value="{{selected.id}}">
                    <label><span>Base %</span><input type="number" step="0.01" name="baseRate" value="{{selected.growth.baseRate}}"></label>
                    <label><span>Safe Bonus</span><input type="number" step="0.01" name="safeBonus" value="{{selected.growth.safeBonus}}"></label>
                    <label><span>GM Food Modifier</span><input type="number" step="0.01" name="foodBonus" value="{{selected.growth.foodBonus}}"></label>
                    <label><span>Migration</span><input type="number" step="0.01" name="migrationBonus" value="{{selected.growth.migrationBonus}}"></label>
                    <label><span>War</span><input type="number" step="0.01" name="warPenalty" value="{{selected.growth.warPenalty}}"></label>
                    <label><span>Famine</span><input type="number" step="0.01" name="faminePenalty" value="{{selected.growth.faminePenalty}}"></label>
                    <label><span>Plague</span><input type="number" step="0.01" name="plaguePenalty" value="{{selected.growth.plaguePenalty}}"></label>
                    <label><span>Tax</span><input type="number" step="0.01" name="taxPenalty" value="{{selected.growth.taxPenalty}}"></label>
                    <label><span>Raid</span><input type="number" step="0.01" name="raidPenalty" value="{{selected.growth.raidPenalty}}"></label>
                    <label><span>Other</span><input type="number" step="0.01" name="otherModifier" value="{{selected.growth.otherModifier}}"></label>
                    <label><span>Override Rate</span><input type="number" step="0.01" name="overrideRate" value="{{selected.growth.overrideRate}}"></label>
