                  {{#each selected.pendingEvents}}
                    <form class="ds-event-card ds-severity-{{severity}}" data-action-form="resolveMonthEvent">
                      <input type="hidden" name="settlementId" value="{{../selected.id}}">
                      <input type="hidden" name="eventId" value="{{id}}">
                      <input type="hidden" name="resolution" value="apply">
                      <div class="ds-event-card-heading"><div><span class="ds-event-roll">{{rawRoll}} {{#if modifier}}({{modifier}}){{/if}} = {{finalRoll}}</span><h3>{{name}}</h3><small>Month {{month}} / {{severityLabel}}</small></div>{{#if hasImage}}<img src="{{imageUrl}}" alt="{{name}}">{{else}}<i class="fa-solid fa-dice-d20"></i>{{/if}}</div>
                      <p>{{description}}</p>
                      {{#if mitigationText}}<p class="ds-mitigation"><i class="fa-solid fa-shield"></i> {{mitigationText}}</p>{{/if}}
                      <div class="ds-event-effect-grid">
                        <label><span>Income %</span><input type="number" name="incomePercent" value="{{effects.incomePercent}}"></label>
                        <label><span>Building Upkeep %</span><input type="number" name="buildingUpkeepPercent" value="{{effects.buildingUpkeepPercent}}"></label>
                        <label><span>Food Output %</span><input type="number" name="foodOutputPercent" value="{{effects.foodOutputPercent}}"></label>
                        <label><span>Materials Output %</span><input type="number" name="materialsOutputPercent" value="{{effects.materialsOutputPercent}}"></label>
                        <label><span>Construction CP %</span><input type="number" name="constructionPercent" value="{{effects.constructionPercent}}"></label>
                        <label><span>Recruitment Cost %</span><input type="number" name="recruitmentCostPercent" value="{{effects.recruitmentCostPercent}}"></label>
                        <label><span>Army Upkeep %</span><input type="number" name="militaryUpkeepPercent" value="{{effects.militaryUpkeepPercent}}"></label>
                        <label><span>Growth % Points</span><input type="number" step="0.05" name="growth" value="{{effects.growth}}"></label>
                        <label><span>Order</span><input type="number" name="publicOrder" value="{{effects.publicOrder}}"></label>
                        <label><span>Duration</span><input type="number" name="duration" value="{{duration}}" min="0" max="12"></label>
                      </div>
                      <label><span>Resolution Note</span><textarea name="gmNote" rows="2"></textarea></label>
                      <div class="ds-record-actions"><button type="submit" class="ds-primary"><i class="fa-solid fa-check"></i><span>Apply Modifier</span></button><button type="button" data-click-action="resolveMonthEvent" data-settlement-id="{{../selected.id}}" data-event-id="{{id}}" data-resolution="narrative"><i class="fa-solid fa-book-open"></i><span>Narrative Only</span></button><button type="button" data-click-action="rerollMonthEvent" data-settlement-id="{{../selected.id}}" data-event-id="{{id}}" data-confirm="Reroll and replace this event?"><i class="fa-solid fa-dice"></i><span>Reroll</span></button><button type="button" data-click-action="resolveMonthEvent" data-settlement-id="{{../selected.id}}" data-event-id="{{id}}" data-resolution="ignore"><i class="fa-solid fa-ban"></i><span>Ignore</span></button></div>
                    </form>
