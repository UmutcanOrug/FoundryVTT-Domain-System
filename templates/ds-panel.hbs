                        <button type="button" class="ds-danger" data-click-action="deleteProject" data-settlement-id="{{../selected.id}}" data-project-id="{{id}}" data-confirm="Delete this construction record?"><i class="fa-solid fa-trash"></i><span>Delete Record</span></button>
                      </form>
                    {{else}}<div class="ds-empty-state"><p>No construction records.</p></div>{{/each}}
                  </div>
                </details>
                <details class="ds-panel">
                  <summary><span><i class="fa-solid fa-people-pulling"></i> Recruitment Records</span><strong>{{selected.recruitment.length}}</strong></summary>
                  <div class="ds-repair-list">
                    {{#each selected.recruitment}}
                      <form data-action-form="updateRecruitment">
                        <input type="hidden" name="settlementId" value="{{../selected.id}}"><input type="hidden" name="recruitmentId" value="{{id}}">
                        <div class="ds-panel-heading"><h3>{{troopTypeName}}</h3><button type="submit"><i class="fa-solid fa-floppy-disk"></i></button></div>
                        <div class="ds-form-grid"><label><span>Unit</span><select name="troopType">{{#each troopTypeOptions}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>{{/each}}</select></label><label><span>Training</span><input value="{{sourceName}}" disabled></label><label><span>Regiment Name</span><input name="regimentName" value="{{regimentName}}"></label><label><span>Status</span><select name="status">{{#each statusOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label><label><span>Target Count</span><input type="number" name="targetCount" value="{{targetCount}}" min="0"></label><label><span>Trained</span><input type="number" name="trained" value="{{trained}}" min="0"></label><label class="ds-full"><span>Actor UUID</span><div class="ds-input-action"><input name="actorUuid" value="{{actorUuid}}" data-actor-drop><button type="button" data-open-actor="{{actorUuid}}" {{#unless actorUuid}}disabled{{/unless}}><i class="fa-solid fa-address-card"></i></button></div></label><label class="ds-full"><span>Image</span><div class="ds-input-action"><input name="imageUrl" value="{{imageUrl}}"><button type="button" data-file-picker="[name='imageUrl']"><i class="fa-solid fa-image"></i></button></div></label><label class="ds-full"><span>Notes</span><textarea name="notes" rows="2">{{notes}}</textarea></label></div>
                        <button type="button" class="ds-danger" data-click-action="deleteRecruitment" data-settlement-id="{{../selected.id}}" data-recruitment-id="{{id}}" data-confirm="Delete this recruitment record?"><i class="fa-solid fa-trash"></i><span>Delete Record</span></button>
                      </form>
                    {{else}}<div class="ds-empty-state"><p>No recruitment records.</p></div>{{/each}}
                  </div>
                </details>
              </div>
            </section>

            <section class="ds-section">
              <div class="ds-section-heading"><div><h2>Settlement Templates</h2><p>Blank Hamlet, Starter Hamlet, Starter Village, and Starter Town are always available</p></div></div>
              <div class="ds-gm-command-grid">
                <form class="ds-panel" data-action-form="addSettlementTemplate"><div class="ds-panel-heading"><h3>Create Blank Template</h3><button type="submit"><i class="fa-solid fa-plus"></i></button></div><label><span>Template Name</span><input name="name" value="Custom Hamlet"></label></form>
                <form class="ds-panel" data-action-form="saveSettlementAsTemplate"><input type="hidden" name="settlementId" value="{{selected.id}}"><div class="ds-panel-heading"><h3>Save Current Settlement</h3><button type="submit"><i class="fa-solid fa-clone"></i></button></div><label><span>Template Name</span><input name="name" value="{{selected.name}} Template"></label><label><span>Description</span><input name="description" value="Saved from {{selected.name}}"></label></form>
              </div>
              <div class="ds-template-editor-list">
                {{#each settlementTemplates}}
                  <details class="ds-record-card">
                    <summary><div><h3>{{name}}</h3><p>{{tier}} / {{population}} POP / {{buildingCount}} buildings</p></div><i class="fa-solid fa-chevron-down"></i></summary>
                    <form class="ds-editor-body" data-action-form="updateSettlementTemplate">
                      <input type="hidden" name="templateId" value="{{id}}">
                      <div class="ds-form-grid"><label><span>Name</span><input name="name" value="{{name}}"></label><label><span>Tier</span><select name="tier">{{#each tierOptions}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>{{/each}}</select></label><label><span>Population</span><input type="number" name="population" value="{{population}}" min="0"></label><label><span>Treasure</span><input type="number" name="treasure" value="{{treasure}}" min="0"></label><label><span>Materials</span><input type="number" name="materials" value="{{materials}}" min="0"></label><label><span>Public Order</span><input type="number" name="publicOrder" value="{{publicOrder}}" min="0" max="100"></label><label><span>Manpower Bonus</span><input type="number" name="manpowerBonus" value="{{manpowerBonus}}"></label><label class="ds-full"><span>Terrain Tags</span><input name="terrainTags" value="{{terrainTagsText}}"></label><label class="ds-full"><span>Description</span><textarea name="description" rows="2">{{description}}</textarea></label></div>
                      <div class="ds-record-actions"><button type="submit"><i class="fa-solid fa-floppy-disk"></i><span>Save Template</span></button>{{#unless isBuiltIn}}<button type="button" class="ds-danger" data-click-action="deleteSettlementTemplate" data-template-id="{{id}}" data-confirm="Delete this custom settlement template?"><i class="fa-solid fa-trash"></i></button>{{/unless}}</div>
                    </form>
                  </details>
                {{/each}}
              </div>
            </section>

            <section class="ds-danger-zone"><div><h2>Settlement Record</h2><p>De Laurent is never overwritten by settlement templates.</p></div><button type="button" class="ds-danger" data-click-action="deleteSettlement" data-settlement-id="{{selected.id}}" data-confirm="Delete this settlement?"><i class="fa-solid fa-trash"></i><span>Delete Settlement</span></button></section>
          </section>
        {{/if}}
      {{/if}}
    </main>
  </div>
</div>
