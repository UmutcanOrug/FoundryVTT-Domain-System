                <label class="ds-full"><span>Settlement Hero Image</span><div class="ds-input-action"><input name="imageUrl" value="{{selected.imageUrl}}"><button type="button" data-file-picker="[name='imageUrl']"><i class="fa-solid fa-image"></i></button></div></label>
                <label class="ds-full"><span>District Board Background</span><div class="ds-input-action"><input name="districtBackgroundUrl" value="{{selected.districtBackgroundUrl}}"><button type="button" data-file-picker="[name='districtBackgroundUrl']"><i class="fa-solid fa-image"></i></button></div></label>
                <label><span>Background Shade %</span><input type="number" name="backgroundOverlay" value="{{selected.backgroundOverlay}}" min="0" max="90"></label>
                <label><span>Governor</span><input name="governorName" value="{{selected.governorName}}"></label>
                <label class="ds-full"><span>Advisor Portrait</span><div class="ds-input-action"><input name="portraitUrl" value="{{selected.portraitUrl}}"><button type="button" data-file-picker="[name='portraitUrl']"><i class="fa-solid fa-image"></i></button></div></label>
                <label class="ds-full"><span>Overview Description</span><textarea name="systemNotes" rows="2">{{selected.systemNotes}}</textarea></label>
                <fieldset class="ds-check-grid ds-full"><legend>Assigned Players</legend>{{#each userOptions}}<label><input type="checkbox" name="ownerUserIds" value="{{id}}" {{#if checked}}checked{{/if}}> {{name}}</label>{{/each}}</fieldset>
              </div>
            </form>

            <section class="ds-gm-command-grid">
              <form class="ds-panel" data-action-form="addBuilding">
                <input type="hidden" name="settlementId" value="{{selected.id}}">
                <div class="ds-panel-heading"><div><h2>Direct Building Placement</h2><p>No cost or prerequisite check</p></div><button type="submit"><i class="fa-solid fa-building-circle-check"></i></button></div>
                <label><span>Building Node</span><select name="catalogId">{{#each gmNormalBuildingOptions}}<option value="{{id}}">{{label}}</option>{{/each}}</select></label>
                <label><span>Empty District</span><select name="slotId"><option value="">First compatible empty district</option>{{#each selected.slots}}{{#if availableForDirectAdd}}<option value="{{id}}">{{label}} / {{allowedCategory}}</option>{{/if}}{{/each}}</select></label>
              </form>
              <form class="ds-panel" data-action-form="addBuilding">
                <input type="hidden" name="settlementId" value="{{selected.id}}">
