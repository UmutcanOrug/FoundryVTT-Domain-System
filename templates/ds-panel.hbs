                              <div><strong>{{name}}{{#if special}} <i class="fa-solid fa-star ds-special-mark"></i>{{/if}}</strong><small>{{description}}</small><span class="ds-effect-badges">{{#each effectBadges}}<em class="{{kind}}"><i class="fa-solid {{icon}}"></i>{{label}}</em>{{/each}}</span><small>{{nodeTierLabel}} / {{crownCostDisplay}} Crown / {{materialCostDisplay}} Materials / {{cpCostDisplay}} CP</small><p>{{#if blocked}}{{blockReason}}{{else}}{{requirementDisplay}}{{/if}}</p></div>
                              <button type="submit" class="ds-primary" {{#unless canQueue}}disabled{{/unless}} title="{{blockReason}}"><i class="fa-solid fa-hammer"></i></button>
                            </form>
                          {{/each}}
                        </div>
