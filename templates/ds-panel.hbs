<div class="ds-root {{#unless isGM}}ds-player{{/unless}}">
  <header class="ds-header">
    <div class="ds-title">
      <span class="ds-title-mark"><i class="fa-solid fa-building-columns"></i></span>
      <div>
        <h1>DS: Domain System</h1>
        <p>Month {{month}}{{#if selected}} / {{selected.name}} / {{selected.tierLabel}}{{/if}}</p>
      </div>
    </div>

    {{#if selected}}
      <div class="ds-resource-strip">
        <div class="ds-resource"><i class="fa-solid fa-users"></i><span>Total POP</span><strong>{{selected.summary.totalPop}}</strong></div>
        <div class="ds-resource"><i class="fa-solid fa-person-digging"></i><span>Free POP</span><strong>{{selected.summary.freePop}}</strong></div>
        <div class="ds-resource"><i class="fa-solid fa-hammer"></i><span>Construction CP</span><strong>{{selected.summary.cpThisMonth}}</strong></div>
        <div class="ds-resource"><i class="fa-solid fa-vault"></i><span>Treasure</span><strong>{{selected.treasure}}</strong></div>
        <div class="ds-resource"><i class="fa-solid fa-shield-halved"></i><span>Army Upkeep</span><strong>{{selected.summary.militaryCost}}</strong></div>
        <div class="ds-resource"><i class="fa-solid fa-scale-balanced"></i><span>Net</span><strong>{{selected.summary.netIncome}}</strong></div>
      </div>
    {{/if}}
  </header>

  <div class="ds-shell">
    <aside class="ds-sidebar">
      <div class="ds-search-row">
        <input type="search" data-search-settlements value="{{search}}" placeholder="Search settlements">
        {{#if isGM}}<button type="button" data-click-action="addSettlement" title="Create Starter Village"><i class="fa-solid fa-plus"></i></button>{{/if}}
      </div>
      <div class="ds-settlement-list">
        {{#each settlements}}
          <button type="button" class="ds-settlement-button {{#if active}}active{{/if}}" data-select-settlement="{{id}}">
            <strong>{{name}}</strong>
            <span>{{type}} / {{region}}</span>
            <small>POP {{pop}} / Net {{net}}{{#if processedThisMonth}} / Processed{{else}} / Pending{{/if}}{{#if warnings}} / {{warnings}} warnings{{/if}}</small>
          </button>
        {{/each}}
      </div>
    </aside>

    <main class="ds-main">
      {{#unless hasVisibleSettlements}}<section class="ds-empty"><h2>No Settlement Assigned</h2></section>{{/unless}}

      {{#if selected}}
        {{#if selected.hasWarnings}}
          <section class="ds-warning-band">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div>{{#each selected.warnings}}<p>{{this}}</p>{{/each}}</div>
          </section>
        {{/if}}

        <nav class="ds-nav" aria-label="Domain System sections">
          {{#each tabs}}
            <button type="button" class="ds-nav-item {{#if active}}active{{/if}}" data-tab="{{id}}" title="{{label}}">
              <i class="fa-solid {{icon}}"></i><span>{{label}}</span>
            </button>
          {{/each}}
        </nav>

        {{#if (eq activeTab "overview")}}
          <section class="ds-pane">
            <section class="ds-planet-hero" style="{{selected.heroStyle}}">
              <div class="ds-hero-copy">
                <span class="ds-kicker">{{selected.tierLabel}} / {{selected.region}}</span>
                <h2>{{selected.name}}</h2>
                <p>{{selected.biomeDescription}}</p>
                <div class="ds-chip-row">
                  <span><i class="fa-solid fa-landmark"></i> {{selected.coreName}}</span>
                  <span><i class="fa-solid fa-layer-group"></i> {{selected.summary.slotUsage}} slots</span>
                  <span class="{{#if selected.processedThisMonth}}ds-good{{else}}ds-warn{{/if}}"><i class="fa-solid fa-calendar-check"></i> {{selected.processStatusLabel}}</span>
                </div>
              </div>
              <div class="ds-advisor-block">
                <div class="ds-advisor-portrait">{{#if selected.portraitUrl}}<img src="{{selected.portraitUrl}}" alt="Advisor">{{else}}<i class="fa-solid fa-user-tie"></i>{{/if}}</div>
                <div><span>Governor</span><strong>{{selected.governorName}}</strong><small>{{selected.ownerNames}}</small></div>
              </div>
            </section>

            <section class="ds-metrics-grid ds-overview-metrics">
              <div><span>Gross Income</span><strong>{{selected.summary.grossIncome}}</strong></div>
              <div><span>Building Upkeep</span><strong>{{selected.summary.buildingUpkeep}}</strong></div>
              <div><span>Army Upkeep</span><strong>{{selected.summary.militaryCost}}</strong></div>
              <div><span>Growth</span><strong>{{selected.summary.growthRate}}</strong></div>
              <div><span>Recruitment / Month</span><strong>{{selected.summary.recruitmentCapacity}}</strong></div>
              <div><span>Next POP</span><strong>{{selected.summary.projectedPop}}</strong></div>
            </section>

            <section class="ds-command-grid">
              <div class="ds-section">
                <div class="ds-section-heading"><h2><i class="fa-solid fa-hammer"></i> Construction Queue</h2><span>{{selected.summary.cpThisMonth}} base CP</span></div>
                {{#each selected.activeProjects}}
                  <article class="ds-compact-row"><span class="ds-row-icon"><i class="fa-solid {{categoryIcon}}"></i></span><div><strong>#{{queueNumber}} {{name}}</strong><small>{{cpPaidDisplay}} / {{requiredCpDisplay}} CP / ETA {{months}} month(s)</small></div><span>{{statusLabel}}</span></article>
                {{else}}<div class="ds-inline-empty">No active construction.</div>{{/each}}
              </div>
              <div class="ds-section">
                <div class="ds-section-heading"><h2><i class="fa-solid fa-user-plus"></i> Recruitment Queue</h2><span>{{selected.summary.recruitmentCapacity}} capacity</span></div>
                {{#each selected.activeRecruitment}}
                  <article class="ds-compact-row"><span class="ds-row-icon"><i class="fa-solid fa-user-shield"></i></span><div><strong>{{regimentName}}</strong><small>{{troopTypeName}} / {{progress}} / {{sourceName}}</small></div><span>{{statusLabel}}</span></article>
                {{else}}<div class="ds-inline-empty">No active recruitment.</div>{{/each}}
              </div>
            </section>

            <section class="ds-section">
              <div class="ds-section-heading"><h2>Settlement Districts</h2><span>{{selected.summary.usedSlots}} used / {{selected.summary.unlockedSlots}} unlocked</span></div>
              <div class="ds-slot-mini-grid">
                {{#each selected.slots}}
                  <article class="ds-slot-mini {{#if locked}}locked{{/if}} {{#if occupied}}{{building.category}}{{/if}}">
                    {{#if locked}}
                      <i class="fa-solid fa-lock"></i><strong>{{label}}</strong><small>{{unlockCostDisplay}} Crown</small>
                    {{else if hasProject}}
                      <i class="fa-solid fa-hammer"></i><strong>{{project.name}}</strong><small>{{project.progressPercent}}%</small>
                    {{else if occupied}}
                      {{#if building.hasImage}}<img src="{{building.imageUrl}}" alt="{{building.name}}">{{else}}<i class="fa-solid {{building.categoryIcon}}"></i>{{/if}}
                      <strong>{{building.name}}</strong><small>Tier {{building.nodeTier}}{{#if building.special}} / Special{{/if}}</small>
                    {{else}}
                      <i class="fa-solid fa-plus"></i><strong>{{label}}</strong><small>Empty district</small>
                    {{/if}}
                  </article>
                {{/each}}
              </div>
            </section>

            <section class="ds-section">
              <div class="ds-section-heading"><h2>Raised Forces</h2><span>{{selected.summary.mpUsed}} manpower</span></div>
              <div class="ds-regiment-strip">
                {{#each selected.troops}}
                  <article class="ds-regiment-chip">{{#if hasImage}}<img src="{{imageUrl}}" alt="{{displayName}}">{{else}}<i class="fa-solid fa-shield-halved"></i>{{/if}}<div><strong>{{displayName}}</strong><small>{{count}} / {{mode}} / {{cost}} upkeep</small></div></article>
                {{else}}<div class="ds-inline-empty">No raised forces.</div>{{/each}}
              </div>
            </section>
          </section>
        {{/if}}

        {{#if (eq activeTab "town")}}
          <section class="ds-pane">
            <section class="ds-progression-band">
              <div class="ds-tier-current"><span>Current Settlement</span><strong>{{selected.progression.current.name}}</strong><small>{{selected.progression.current.coreName}} / {{selected.progression.current.openSlots}} open slots</small></div>
              <div class="ds-tier-track"><div style="width: {{selected.progression.populationProgress}}%"></div></div>
              {{#if selected.progression.hasNext}}
                <div class="ds-tier-next"><span>Next Settlement</span><strong>{{selected.progression.next.name}}</strong><small>{{selected.progression.next.minPopulationDisplay}} POP / {{selected.progression.next.promotionCostDisplay}} Crown / {{selected.progression.next.promotionCpDisplay}} CP</small></div>
                <form data-action-form="queueSettlementUpgrade">
                  <input type="hidden" name="settlementId" value="{{selected.id}}">
                  <button type="submit" class="ds-primary" {{#unless selected.progression.canQueue}}disabled{{/unless}} title="{{selected.progression.blockedReason}}"><i class="fa-solid fa-landmark"></i><span>Develop {{selected.progression.next.coreName}}</span></button>
                </form>
              {{else}}<strong>Maximum settlement tier reached</strong>{{/if}}
            </section>

            <section class="ds-town-grid">
              <form class="ds-panel" data-action-form="updateBasics">
                <input type="hidden" name="settlementId" value="{{selected.id}}">
                <div class="ds-panel-heading"><h2>Settlement Profile</h2><button type="submit" title="Save" {{#unless selected.canEditBasics}}disabled{{/unless}}><i class="fa-solid fa-floppy-disk"></i></button></div>
                <div class="ds-form-grid">
                  <label><span>Name</span><input name="name" value="{{selected.name}}" {{#unless selected.canEditBasics}}disabled{{/unless}}></label>
                  <label><span>Region</span><input name="region" value="{{selected.region}}" {{#unless selected.canEditBasics}}disabled{{/unless}}></label>
                  <label class="ds-full"><span>Terrain Tags</span><input name="terrainTags" value="{{selected.terrainTagsText}}" {{#unless selected.canEditBasics}}disabled{{/unless}}></label>
                  <label class="ds-full"><span>Biome Tags</span><input name="biomeTags" value="{{selected.biomeTagsText}}" {{#unless selected.canEditBasics}}disabled{{/unless}}></label>
                  <label class="ds-full"><span>Public Notes</span><textarea name="notes" rows="3" {{#unless selected.canEditBasics}}disabled{{/unless}}>{{selected.notes}}</textarea></label>
                </div>
              </form>

              <section class="ds-panel">
                <div class="ds-panel-heading"><h2>Population and Growth</h2></div>
                <div class="ds-metrics-grid">
                  <div><span>Total POP</span><strong>{{selected.summary.totalPop}}</strong></div>
                  <div><span>Assigned</span><strong>{{selected.summary.economicWorkers}} / {{selected.summary.militaryWorkers}}</strong></div>
                  <div><span>Free POP</span><strong>{{selected.summary.freePop}}</strong></div>
                  <div><span>Monthly Change</span><strong>{{selected.summary.popChange}}</strong></div>
                </div>
                {{#if isGM}}
                  <form data-action-form="updateGrowth" class="ds-form-grid ds-top-gap">
                    <input type="hidden" name="settlementId" value="{{selected.id}}">
                    <label><span>Base %</span><input type="number" step="0.01" name="baseRate" value="{{selected.growth.baseRate}}"></label>
                    <label><span>Safe Bonus</span><input type="number" step="0.01" name="safeBonus" value="{{selected.growth.safeBonus}}"></label>
                    <label><span>Food Bonus</span><input type="number" step="0.01" name="foodBonus" value="{{selected.growth.foodBonus}}"></label>
                    <label><span>Migration</span><input type="number" step="0.01" name="migrationBonus" value="{{selected.growth.migrationBonus}}"></label>
                    <label><span>War</span><input type="number" step="0.01" name="warPenalty" value="{{selected.growth.warPenalty}}"></label>
                    <label><span>Other</span><input type="number" step="0.01" name="otherModifier" value="{{selected.growth.otherModifier}}"></label>
                    <input type="hidden" name="faminePenalty" value="{{selected.growth.faminePenalty}}"><input type="hidden" name="plaguePenalty" value="{{selected.growth.plaguePenalty}}"><input type="hidden" name="taxPenalty" value="{{selected.growth.taxPenalty}}"><input type="hidden" name="raidPenalty" value="{{selected.growth.raidPenalty}}"><input type="hidden" name="overrideRate" value="{{selected.growth.overrideRate}}"><input type="hidden" name="overridePopChange" value="{{selected.growth.overridePopChange}}"><input type="hidden" name="roundDown" value="true">
                    <div class="ds-record-actions ds-full"><button type="submit"><i class="fa-solid fa-floppy-disk"></i><span>Save Growth</span></button></div>
                  </form>
                {{/if}}
              </section>
            </section>

            <section class="ds-section">
              <div class="ds-section-heading"><h2>Completed Buildings</h2><span>POP assignments affect income and construction CP</span></div>
              <div class="ds-building-list">
                {{#each selected.buildings}}
                  <details class="ds-record-card">
                    <summary>
                      <div class="ds-summary-image">{{#if hasImage}}<img src="{{imageUrl}}" alt="{{name}}">{{else}}<i class="fa-solid {{categoryIcon}}"></i>{{/if}}</div>
                      <div><h3>{{name}}{{#if special}} <i class="fa-solid fa-star ds-special-mark" title="Special"></i>{{/if}}</h3><p>{{categoryLabel}} / Tier {{nodeTier}}</p><small>{{assignedPop}} / {{workerCapacity}} POP / Output {{output}} / Upkeep {{buildingUpkeepDisplay}}</small></div>
                      <i class="fa-solid fa-chevron-down"></i>
                    </summary>
                    <form class="ds-editor-body" data-action-form="updateBuilding">
                      <input type="hidden" name="settlementId" value="{{@root.selected.id}}"><input type="hidden" name="buildingId" value="{{id}}">
                      <div class="ds-form-grid">
                        <label><span>Assigned POP</span><input type="number" name="assignedPop" value="{{assignedPop}}" min="0" {{#unless canEditAssignments}}disabled{{/unless}}></label>
                        {{#if @root.isGM}}
                          <label><span>Name</span><input name="name" value="{{name}}"></label>
                          <label><span>Category</span><select name="category">{{#each categoryOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
                          <label><span>Worker Capacity</span><input type="number" name="workers" value="{{workers}}" min="0"></label>
                          <label><span>GP / Worker</span><input type="number" name="rate" value="{{rate}}" min="0"></label>
                          <label><span>Flat Output</span><input type="number" name="flatOutput" value="{{flatOutput}}"></label>
                          <label><span>Building Upkeep</span><input type="number" name="buildingUpkeep" value="{{buildingUpkeep}}" min="0"></label>
                          <label><span>Construction Bonus</span><input type="number" name="constructionBonus" value="{{constructionBonus}}" min="0"></label>
                          <label><span>Recruit / Month</span><input type="number" name="recruitPerLevel" value="{{recruitPerLevel}}" min="0"></label>
                          <label><span>Professional Capacity</span><input type="number" name="professionalCapacity" value="{{professionalCapacity}}" min="0"></label>
                          <label><span>Militia Capacity</span><input type="number" name="militiaCapacity" value="{{militiaCapacity}}" min="0"></label>
                          <label><span>Recruit Discount %</span><input type="number" name="recruitmentDiscount" value="{{recruitmentDiscount}}" min="0" max="90"></label>
                          <label><span>Upkeep Discount %</span><input type="number" name="upkeepDiscount" value="{{upkeepDiscount}}" min="0" max="90"></label>
                          <label><span>Growth %</span><input type="number" step="0.01" name="growth" value="{{growth}}"></label>
                          <label class="ds-full"><span>Image</span><div class="ds-input-action"><input name="imageUrl" value="{{imageUrl}}"><button type="button" data-file-picker="[name='imageUrl']" title="Pick Image"><i class="fa-solid fa-image"></i></button></div></label>
                          <label class="ds-toggle"><input type="checkbox" name="active" data-bool {{activeChecked}}><span>Active</span></label>
                          <label class="ds-toggle"><input type="checkbox" name="special" data-bool {{specialChecked}}><span>Special</span></label>
                          <label class="ds-toggle"><input type="checkbox" name="gmOnly" data-bool {{gmOnlyChecked}}><span>GM Only</span></label>
                          <label class="ds-toggle"><input type="checkbox" name="canRecruit" data-bool {{canRecruitChecked}}><span>Can Recruit Units</span></label>
                          <fieldset class="ds-check-grid ds-full"><legend>Recruitable Units</legend><input type="hidden" name="recruitableUnitIds" value="">{{#each unlockUnitOptions}}<label><input type="checkbox" name="recruitableUnitIds" value="{{id}}" {{#if checked}}checked{{/if}}> {{name}}</label>{{/each}}</fieldset>
                        {{/if}}
                        <label class="ds-full"><span>Notes</span><textarea name="notes" rows="2">{{notes}}</textarea></label>
                      </div>
                      <div class="ds-record-actions"><button type="submit" {{#unless canEditAssignments}}disabled{{/unless}}><i class="fa-solid fa-floppy-disk"></i><span>Save</span></button>{{#if @root.isGM}}<button type="button" class="ds-danger" data-click-action="deleteBuilding" data-settlement-id="{{@root.selected.id}}" data-building-id="{{id}}" data-confirm="Delete this completed building?"><i class="fa-solid fa-trash"></i></button>{{/if}}</div>
                    </form>
                  </details>
                {{else}}<div class="ds-inline-empty">No completed buildings.</div>{{/each}}
              </div>
            </section>
          </section>
        {{/if}}

        {{#if (eq activeTab "construction")}}
          <section class="ds-pane">
            <section class="ds-section">
              <div class="ds-section-heading"><h2>Construction Queue</h2><span>{{selected.summary.cpThisMonth}} CP shared across active projects</span></div>
              <div class="ds-queue-list">
                {{#each selected.activeProjects}}
                  <article class="ds-queue-card">
                    <div class="ds-queue-image">{{#if hasImage}}<img src="{{imageUrl}}" alt="{{name}}">{{else}}<i class="fa-solid {{categoryIcon}}"></i>{{/if}}</div>
                    <div class="ds-queue-copy"><div><span class="ds-order-badge">#{{queueNumber}}</span><h3>{{name}}</h3><small>{{statusLabel}}</small></div><p>{{cpPaidDisplay}} / {{requiredCpDisplay}} CP / {{cpRate}} expected CP / ETA {{months}} month(s)</p><div class="ds-progress"><span style="width: {{progressPercent}}%"></span></div></div>
                    {{#if canManage}}<div class="ds-queue-actions"><form class="ds-hire-cp" data-action-form="hireConstructionCp"><input type="hidden" name="settlementId" value="{{@root.selected.id}}"><input type="hidden" name="projectId" value="{{id}}"><input type="number" name="cp" value="10" min="1" title="{{hireCostPerCp}} Crown per CP"><button type="submit" {{#unless canHireCp}}disabled{{/unless}} title="Hire one-use CP; {{hiredCpPending}} currently pending"><i class="fa-solid fa-person-digging"></i></button></form><div class="ds-icon-actions"><button type="button" data-click-action="moveProject" data-direction="up" data-settlement-id="{{@root.selected.id}}" data-project-id="{{id}}" title="Move Up" {{#unless canMoveUp}}disabled{{/unless}}><i class="fa-solid fa-arrow-up"></i></button><button type="button" data-click-action="moveProject" data-direction="down" data-settlement-id="{{@root.selected.id}}" data-project-id="{{id}}" title="Move Down" {{#unless canMoveDown}}disabled{{/unless}}><i class="fa-solid fa-arrow-down"></i></button><button type="button" class="ds-danger" data-click-action="cancelProject" data-settlement-id="{{@root.selected.id}}" data-project-id="{{id}}" data-confirm="Cancel this project and refund its Crown?" title="Cancel"><i class="fa-solid fa-xmark"></i></button></div></div>{{/if}}
                  </article>
                {{else}}<div class="ds-inline-empty">Construction queue is empty.</div>{{/each}}
              </div>
            </section>

            <section class="ds-section">
              <div class="ds-section-heading"><h2>District Slots</h2><span>Buildings develop along branches inside their slot</span></div>
              <div class="ds-construction-tools">
                <div class="ds-segmented"><button type="button" data-construction-category="all" class="{{#if (eq constructionCategory 'all')}}active{{/if}}">All</button><button type="button" data-construction-category="economic" class="{{#if (eq constructionCategory 'economic')}}active{{/if}}"><i class="fa-solid fa-industry"></i> Economic</button><button type="button" data-construction-category="military" class="{{#if (eq constructionCategory 'military')}}active{{/if}}"><i class="fa-solid fa-shield-halved"></i> Military</button></div>
                <input type="search" data-search-construction value="{{constructionSearch}}" placeholder="Search building chains">
              </div>
              <div class="ds-slot-board">
                {{#each selected.slots}}
                  <article class="ds-slot-card {{#if locked}}locked{{/if}} {{#if occupied}}{{building.category}}{{/if}}">
                    <header>
                      <span>{{label}}</span>
                      <small>{{#if locked}}Locked{{else}}{{allowedCategory}}{{/if}}</small>
                    </header>
                    {{#if locked}}
                      <div class="ds-slot-empty"><i class="fa-solid fa-lock"></i><strong>{{unlockCostDisplay}} Crown</strong><small>{{#if gmLocked}}GM locked{{else}}Purchasable district{{/if}}</small></div>
                      <button type="button" data-click-action="unlockSlot" data-settlement-id="{{@root.selected.id}}" data-slot-id="{{id}}" {{#unless canUnlock}}disabled{{/unless}}><i class="fa-solid fa-unlock"></i><span>Unlock</span></button>
                    {{else if hasProject}}
                      <div class="ds-slot-building">{{#if project.hasImage}}<img src="{{project.imageUrl}}" alt="{{project.name}}">{{else}}<i class="fa-solid fa-hammer"></i>{{/if}}<strong>{{project.name}}</strong><small>{{project.progressPercent}}% / {{project.statusLabel}}</small></div>
                    {{else if occupied}}
                      <div class="ds-slot-building">{{#if building.hasImage}}<img src="{{building.imageUrl}}" alt="{{building.name}}">{{else}}<i class="fa-solid {{building.categoryIcon}}"></i>{{/if}}<strong>{{building.name}}{{#if building.special}} <i class="fa-solid fa-star ds-special-mark"></i>{{/if}}</strong><small>Tier {{building.nodeTier}} / {{building.categoryLabel}}</small></div>
                    {{else}}
                      <div class="ds-slot-empty"><i class="fa-solid fa-plus"></i><strong>Empty District</strong><small>{{allowedCategory}}</small></div>
                    {{/if}}

                    {{#if hasChoices}}
                      <details class="ds-slot-options">
                        <summary><i class="fa-solid fa-diagram-project"></i><span>{{#if occupied}}Develop Branch{{else}}Choose Building{{/if}}</span></summary>
                        <div class="ds-slot-choice-list">
                          {{#each choices}}
                            <form class="ds-build-choice {{category}} {{#if blocked}}locked{{/if}}" data-action-form="queueConstruction">
                              <input type="hidden" name="settlementId" value="{{@root.selected.id}}"><input type="hidden" name="slotId" value="{{slotId}}"><input type="hidden" name="catalogId" value="{{id}}">
                              <div class="ds-choice-image">{{#if hasImage}}<img src="{{imageUrl}}" alt="{{name}}">{{else}}<i class="fa-solid {{categoryIcon}}"></i>{{/if}}</div>
                              <div><strong>{{name}}{{#if special}} <i class="fa-solid fa-star ds-special-mark"></i>{{/if}}</strong><small>{{nodeTierLabel}} / {{crownCostDisplay}} Crown / {{cpCostDisplay}} CP</small><p>{{#if blocked}}{{blockReason}}{{else}}{{requirementDisplay}}{{/if}}</p></div>
                              <button type="submit" class="ds-primary" {{#unless canQueue}}disabled{{/unless}} title="{{blockReason}}"><i class="fa-solid fa-hammer"></i></button>
                            </form>
                          {{/each}}
                        </div>
                      </details>
                    {{/if}}

                    {{#if @root.isGM}}
                      <details class="ds-slot-admin"><summary><i class="fa-solid fa-gear"></i><span>Slot</span></summary><form data-action-form="updateSlot"><input type="hidden" name="settlementId" value="{{@root.selected.id}}"><input type="hidden" name="slotId" value="{{id}}"><label><span>Label</span><input name="label" value="{{label}}"></label><label><span>Unlock Cost</span><input type="number" name="unlockCost" value="{{unlockCost}}" min="0"></label><label><span>Category</span><select name="allowedCategory">{{#each allowedCategoryOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label><label class="ds-toggle"><input type="checkbox" name="unlocked" data-bool {{unlockedChecked}}><span>Unlocked</span></label><label class="ds-toggle"><input type="checkbox" name="gmLocked" data-bool {{gmLockedChecked}}><span>GM Locked</span></label><button type="submit"><i class="fa-solid fa-floppy-disk"></i></button></form></details>
                    {{/if}}
                  </article>
                {{/each}}
              </div>
            </section>

            <section class="ds-section">
              <div class="ds-section-heading"><h2>Building Branches</h2><span>Built and queued nodes are marked</span></div>
              <div class="ds-chain-list">
                {{#each selected.buildingChains}}
                  <article class="ds-chain-row {{category}}"><header><strong>{{name}}</strong><span>{{category}}</span></header><div class="ds-chain-nodes">{{#each nodes}}<div class="ds-chain-node {{#if built}}built{{/if}} {{#if queued}}queued{{/if}}" title="{{parentNames}}"><span>Tier {{nodeTier}}</span><strong>{{name}}</strong><small>{{crownCostDisplay}} / {{cpCostDisplay}} CP{{#if unlockNames}} / {{unlockNames}}{{/if}}</small></div>{{/each}}</div></article>
                {{/each}}
              </div>
            </section>
          </section>
        {{/if}}

        {{#if (eq activeTab "recruitment")}}
          <section class="ds-pane">
            <section class="ds-metrics-grid">
              <div><span>Professional</span><strong>{{selected.summary.professionalSoldiers}} / {{selected.summary.professionalCapacity}}</strong></div>
              <div><span>Militia</span><strong>{{selected.summary.militia}} / {{selected.summary.militiaCapacity}}</strong></div>
              <div><span>Manpower</span><strong>{{selected.summary.mpRemaining}}</strong></div>
              <div><span>Recruit / Month</span><strong>{{selected.summary.recruitmentCapacity}}</strong></div>
              <div><span>Recruit Discount</span><strong>{{selected.summary.recruitmentDiscount}}</strong></div>
