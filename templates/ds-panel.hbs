                <div class="ds-snapshot-list">{{#each selected.turnSnapshots}}<article><div><strong>Month {{month}}</strong><span>{{reason}}</span><small>{{createdLabel}}</small></div><button type="button" data-click-action="undoSettlementTurn" data-settlement-id="{{../selected.id}}" data-snapshot-id="{{id}}" data-confirm="Restore this settlement snapshot? Later settlement changes will be replaced."><i class="fa-solid fa-clock-rotate-left"></i><span>Restore</span></button></article>{{/each}}</div>
              {{else}}
