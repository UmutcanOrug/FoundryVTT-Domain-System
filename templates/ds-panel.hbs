                          <label><span>Name</span><input name="name" value="{{name}}"></label>
                          <label><span>Severity</span><select name="severity">{{#each severityOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select></label>
