                          <label class="ds-toggle"><input type="checkbox" name="enabled" data-bool {{enabledChecked}}><span>Enabled</span></label>
                          <label class="ds-toggle"><input type="checkbox" name="usesDefense" data-bool {{usesDefenseChecked}}><span>Siege Defense mitigates harmful effects</span></label>
